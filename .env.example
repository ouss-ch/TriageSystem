# --- App ---
APP_NAME=TriageSystem
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Postgres ---
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=triage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://triage:triage@postgres:5432/triage

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=triage
RABBITMQ_DEFAULT_PASS=triage
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Celery ---
CELERY_BROKER_URL=amqp://triage:triage@rabbitmq:5672//
CELERY_RESULT_BACKEND=db+postgresql://triage:triage@postgres:5432/triage

# --- Email Ingestion ---
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_MAILBOX=INBOX

# --- LLM Provider ---
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5
