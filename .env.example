# --- App ---
APP_NAME=TriageSystem
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Postgres ---
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=triage
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://triage:triage@postgres:5432/triage

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=triage
RABBITMQ_DEFAULT_PASS=triage
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Celery ---
CELERY_BROKER_URL=amqp://triage:triage@rabbitmq:5672//
CELERY_RESULT_BACKEND=db+postgresql://triage:triage@postgres:5432/triage

# --- Email Ingestion ---
# Mailboxes are registered per-mailbox via /api/v1/sweepers (not fixed here).
EMAIL_MAILBOX=INBOX
# How often each mailbox is re-swept (seconds); also sizes the sweep's own lookback window (2x this).
SWEEP_INTERVAL_SECONDS=60

# --- Security ---
# Fernet key encrypting mailbox passwords stored via /sweepers. Generate with:
#   openssl rand -base64 32 | tr '+/' '-_'
ENCRYPTION_KEY=
# Signs JWT login tokens issued by /auth/login. Generate with: openssl rand -base64 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM (local vLLM, OpenAI-compatible) ---
LLM_BASE_URL=http://llm:8000/v1
# Enforced by vLLM itself via --api-key (see docker-compose.yml). Generate with:
#   openssl rand -base64 32 | tr '+/' '-_'
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
HF_TOKEN=
